# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000/api

# AI Coach provider keys (frontend API route)
# OPENAI_API_KEY bo'lsa AI Coach OpenAI ishlatadi.
# OPENAI_API_KEY yo'q bo'lsa ANTHROPIC_API_KEY, u ham bo'lmasa GROQ_API_KEY ishlaydi.
OPENAI_API_KEY=sk-proj-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-api03-your-anthropic-key-here
GROQ_API_KEY=gsk_your-groq-key-here

# Google OAuth (Google Cloud Console → Credentials → OAuth 2.0 Client ID)
# Authorized JavaScript origins: https://aidevix.uz, http://localhost:3000
# https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Instagram API Configuration (Backend uchun)
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token
INSTAGRAM_APP_ID=your_instagram_app_id
INSTAGRAM_APP_SECRET=your_instagram_app_secret

# Telegram Bot Configuration (Backend uchun)  
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHANNEL_ID=@aidevix_channel

# JWT Secret
JWT_SECRET=your_jwt_secret_key

# Database
DATABASE_URL=mongodb://localhost:27017/aidevix